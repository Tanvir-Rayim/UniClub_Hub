{
    "name": "uniqub/uniclubhub",
    "description": "University Club Management Web Application",
    "type": "project",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0",
        "laravel/tinker": "^2.8",
        "barryvdh/laravel-dompdf": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.packagist.org",
            "canonical": false
        }
    ],
    "config": {
        "secure-http": false,
        "allow-plugins": {
            "laravel/framework": true
        }
    }
}
